# Database (same as bot)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=family_chat

# Telegram bot token (needed to download media files for playback)
TELEGRAM_BOT_TOKEN=your_token_here

# Web server
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Media cache (downloaded Telegram files)
MEDIA_CACHE_DIR=media_cache
