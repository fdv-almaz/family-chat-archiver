TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=family_chat
LOG_LEVEL=INFO

# Logging to file (rotated daily). Set LOG_TO_CONSOLE=false to silence stdout.
LOG_FILE=logs/bot.log
LOG_RETENTION_DAYS=7
LOG_TO_CONSOLE=true

# Spelling correction visibility: public (everyone), private (DM to author), off (silent, DB only)
SPELLING_VISIBILITY=public

# --- Совет дня (встроенный планировщик бота; ежедневно в TIP_HOUR:TIP_MINUTE) ---
# Если ANTHROPIC_API_KEY пуст — фича выключена, бот работает как обычно.
ANTHROPIC_API_KEY=
# Модель Claude для совета дня (по умолчанию актуальная Opus).
ANTHROPIC_MODEL=claude-opus-4-8
# Чат для рассылки. Если пусто — берётся самый активный групповой чат из БД.
TIP_CHAT_ID=
# Время рассылки (локальное), по умолчанию 06:00.
TIP_HOUR=6
TIP_MINUTE=0
# Файл с системным промптом совета дня (правится без изменения кода).
# Относительный путь — от каталога python/; по умолчанию общий для Python и Rust
# файл daily_tip_prompt.txt в корне проекта.
TIP_SYSTEM_PROMPT_FILE=../daily_tip_prompt.txt

# Where to save downloaded media files (bot stores them at archive time).
# Relative paths are anchored to the python/ folder (cwd-independent) → python/storage.
# Set an absolute path to store elsewhere; keep it inside the web ALLOWED_MEDIA_DIRS.
MEDIA_STORAGE_DIR=storage
# Skip downloads larger than this in bytes (Telegram Bot API hard limit is 20MB)
MEDIA_MAX_DOWNLOAD_SIZE=20971520
