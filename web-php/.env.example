# Database (same as bot)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=family_chat

# Telegram bot token (needed to download media files for playback)
TELEGRAM_BOT_TOKEN=your_token_here

# Web server — на какой интерфейс и порт биндить веб-UI (используется serve.php).
#   WEB_HOST=127.0.0.1  — только локальный доступ (по умолчанию, безопасно)
#   WEB_HOST=0.0.0.0    — слушать на всех интерфейсах (только за reverse-proxy
#                         с авторизацией и HTTPS — у UI нет встроенной аутентификации!)
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Media cache (downloaded Telegram files)
MEDIA_CACHE_DIR=media_cache

# Security
# Extra hosts allowed as Origin/Referer for state-changing requests
# (POST/DELETE). The request's own Host is always allowed.
# Example: ALLOWED_ORIGINS=archive.example.com,archive.example.com:8000
ALLOWED_ORIGINS=
# Whitelist of directories the /media/{id} endpoint is allowed to read from.
# Defaults to web-php/media_cache, ../python/storage, ../rust/storage.
# ALLOWED_MEDIA_DIRS=/abs/path/one,/abs/path/two
