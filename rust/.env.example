TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=family_chat
LOG_LEVEL=info
RUST_LOG=info,family_chat_archiver=debug

# Logging to file (rotated daily by tracing-appender). Set LOG_TO_CONSOLE=false to silence stdout.
LOG_DIR=logs
LOG_FILE_PREFIX=bot.log
LOG_TO_CONSOLE=true

# Spelling correction visibility: public (everyone), private (DM to author), off (silent, DB only)
SPELLING_VISIBILITY=public
