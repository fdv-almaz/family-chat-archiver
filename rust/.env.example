TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=family_chat
LOG_LEVEL=info
RUST_LOG=info,family_chat_archiver=debug

# Logging to file (rotated daily by tracing-appender). Set LOG_TO_CONSOLE=false to silence stdout.
LOG_DIR=logs
LOG_FILE_PREFIX=bot.log
LOG_TO_CONSOLE=true

# Spelling correction visibility: public (everyone), private (DM to author), off (silent, DB only)
SPELLING_VISIBILITY=public

# --- Совет дня (встроенный планировщик бота; ежедневно в TIP_HOUR:TIP_MINUTE) ---
# Если ANTHROPIC_API_KEY пуст — фича выключена, бот работает как обычно.
ANTHROPIC_API_KEY=
# Модель Claude для совета дня (по умолчанию актуальная Opus).
ANTHROPIC_MODEL=claude-opus-4-8
# Чат для рассылки. Если пусто — берётся самый активный групповой чат из БД.
TIP_CHAT_ID=
# Время рассылки (локальное), по умолчанию 06:00.
TIP_HOUR=6
TIP_MINUTE=0
# Файл с системным промптом совета дня (правится без пересборки).
# Относительный путь — от каталога rust/; по умолчанию общий для Python и Rust
# файл daily_tip_prompt.txt в корне проекта.
TIP_SYSTEM_PROMPT_FILE=../daily_tip_prompt.txt
# Сколько последних отправленных советов передавать модели как «уже было»,
# чтобы она не повторялась (0 — не передавать историю).
TIP_HISTORY_LIMIT=30

# Where to save downloaded media files.
# Relative paths are anchored to the crate root (rust/) at build time, NOT the
# launch directory → always rust/storage even when run from target/release.
# Set an absolute path to store elsewhere; keep it inside the web ALLOWED_MEDIA_DIRS.
MEDIA_STORAGE_DIR=storage
# Skip downloads larger than this in bytes (Bot API hard limit is 20 MB)
MEDIA_MAX_DOWNLOAD_SIZE=20971520
